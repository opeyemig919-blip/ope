require('dotenv').config();
const express = require('express');
const { Telegraf } = require('telegraf');
const { isChromeStoreLink, fetchExtensionData } = require('./scraper');
const { generateAnalysisImage } = require('./imageGen');

const BOT_TOKEN = process.env.TELEGRAM_BOT_TOKEN;
const PORT = process.env.PORT || 3000;
// Railway usually exposes RAILWAY_PUBLIC_DOMAIN automatically once you add a
// public domain to the service. If it's not picked up, set WEBHOOK_URL manually
// in Railway's Variables tab (e.g. myapp-production.up.railway.app — no https://, no trailing slash).
const DOMAIN = process.env.WEBHOOK_URL || process.env.RAILWAY_PUBLIC_DOMAIN;

if (!BOT_TOKEN) {
  console.error('Missing TELEGRAM_BOT_TOKEN env var.');
  process.exit(1);
}

const bot = new Telegraf(BOT_TOKEN);

bot.start((ctx) =>
  ctx.reply(
    'Send me a Chrome Web Store extension link and I will send back an analysis image.\n\nExample:\nhttps://chromewebstore.google.com/detail/name/extensionid'
  )
);

bot.on('text', async (ctx) => {
  const text = ctx.message.text.trim();

  if (!isChromeStoreLink(text)) {
    return ctx.reply(
      "That doesn't look like a Chrome Web Store link. Send something like:\nhttps://chromewebstore.google.com/detail/name/extensionid"
    );
  }

  const statusMsg = await ctx.reply('Analyzing extension...');

  try {
    const data = await fetchExtensionData(text);
    const imageBuffer = await generateAnalysisImage(data);

    await ctx.replyWithPhoto(
      { source: imageBuffer },
      { caption: `${data.name} — analysis complete.` }
    );
  } catch (err) {
    console.error(err);
    await ctx.reply(`Couldn't analyze that extension: ${err.message}`);
  } finally {
    ctx.deleteMessage(statusMsg.message_id).catch(() => {});
  }
});

async function launch() {
  if (DOMAIN) {
    // Webhook mode — required for an always-on server like Railway
    const app = express();
    const secretPath = `/telegraf/${bot.secretPathComponent()}`;

    app.use(bot.webhookCallback(secretPath));
    app.get('/', (_req, res) => res.send('extensionchrbot is running.'));

    app.listen(PORT, async () => {
      const webhookUrl = `https://${DOMAIN}${secretPath}`;
      await bot.telegram.setWebhook(webhookUrl);
      console.log(`Webhook set: ${webhookUrl}`);
      console.log(`Listening on port ${PORT}`);
    });
  } else {
    console.log('No WEBHOOK_URL/RAILWAY_PUBLIC_DOMAIN set — starting in polling mode (local dev).');
    bot.launch();
  }
}

launch();

process.once('SIGINT', () => bot.stop('SIGINT'));
process.once('SIGTERM', () => bot.stop('SIGTERM'));
